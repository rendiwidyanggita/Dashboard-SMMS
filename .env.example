# Public Supabase credentials. Safe for browser use, but configure the real
# values in .env.local for local development and in Vercel Environment
# Variables for deployment.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Use connection strings from the same Supabase project as the public
# credentials above. DATABASE_URL is required by Prisma at runtime.
DATABASE_URL=""

# Optional until Prisma migrations or other direct-connection tooling is used.
DIRECT_URL=""
